{
  "name": "codebase-agent-v2",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "api:dev": "tsx watch src/main.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "start": "node dist/main.js",
    "worker": "node dist/worker.js",
    "db:up": "docker compose up -d postgres qdrant redis"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.15.0",
    "bullmq": "^5.56.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "ioredis": "^5.8.1",
    "openai": "^5.22.0",
    "pg": "^8.16.3",
    "simple-git": "^3.28.0",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^11.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
